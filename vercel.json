{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/contact.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "env": {
    "RESEND_API_KEY": "@resend_api_key"
  },
    "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}